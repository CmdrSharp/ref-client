<Project>
  <!--
    Copy this file to local.targets (which is gitignored) to enable
    post-build steps on your local machine.

    Adjust TargetDir to point to your local Puck plugins folder.
  -->
  <Target Name="PostBuildMoveDll" AfterTargets="Build">
    <PropertyGroup>
      <TargetDir>D:\SteamLibrary\steamapps\common\Puck\Plugins\RefClient</TargetDir>
    </PropertyGroup>

    <MakeDir Directories="$(TargetDir)" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" DestinationFolder="$(TargetDir)" OverwriteReadOnlyFiles="true" />

    <Message Importance="high" Text="Copied $(AssemblyName).dll to $(TargetDir)" />
  </Target>
</Project>
